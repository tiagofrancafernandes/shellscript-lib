{\n    // VSCode Snippets for Shell Script Functions\n    "Shell Script Variable Validation": {\n        "prefix": "vvalid",\n        "body": [\n            "# Validate variable: ${1:var}\",\n            "if [[ -z \$$1 ]]; then\",\n            "    echo 'Variable is not set or empty.';\",\n            "    return 1;\",\n            "fi"\n        ],\n        "description": "Validate if a variable is set and not empty"\n    },\n    "Shell Script Type Checking": {\n        "prefix": "typecheck",\n        "body": [\n            "# Check type of variable: ${1:var}\",\n            "if [[ ! \$$1 =~ ^[0-9]+$ ]]; then\",\n            "    echo 'Not a number.';\",\n            "    return 1;\",\n            "fi"\n        ],\n        "description": "Check if a variable is of type number"\n    },\n    "Shell Script File Operations": {\n        "prefix": "fileop",\n        "body": [\n            "# Function to create a file: ${1:filename}\",\n            "if [[ ! -f \$$1 ]]; then\",\n            "    touch \$$1;\",\n            "    echo 'File created.';\",\n            "else\",\n            "    echo 'File already exists.';\",\n            "fi"\n        ],\n        "description": "Create a file if it doesn't exist"\n    },\n    "Shell Script String Manipulation": {\n        "prefix": "strmanip",\n        "body": [\n            "# Reverse a string: ${1:str}\",\n            "echo \"\$$1 | rev\"\n        ],\n        "description": "Reverse a given string"\n    },\n    "Shell Script Boolean Functions": {\n        "prefix": "boolfn",\n        "body": [\n            "# Function to check if variable is true: ${1:var}\",\n            "if [[ \$$1 == 'true' ]]; then\",\n            "    echo 'It is true!';\",\n            "else\",\n            "    echo 'It is false.';\",\n            "fi"\n        ],\n        "description": "Check if a boolean value is true"\n    },\n    "Shell Script Logging": {\n        "prefix": "log",\n        "body": [\n            "# Log message with timestamp\",\n            "log() {\",\n            "    echo "$(date '+%Y-%m-%d %H:%M:%S')" - $1\n            "}"\n        ],\n        "description": "Log a message with a timestamp"\n    },\n    "Shell Script Date/Time Functions": {\n        "prefix": "datetime",\n        "body": [\n            "# Get current date and time: ${1:format}\",\n            "date '+\$1'"\n        ],\n        "description": "Get the current date/time in specified format"\n    }\n}